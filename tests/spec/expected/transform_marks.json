{
  "cases": [
    {
      "label": "can add a mark",
      "type": "addMark",
      "input": {
        "type": "doc",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "hello there!"
              }
            ]
          }
        ]
      },
      "from": 7,
      "to": 12,
      "mark": "strong",
      "expected": {
        "type": "doc",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "hello "
              },
              {
                "type": "text",
                "marks": [
                  {
                    "type": "strong"
                  }
                ],
                "text": "there"
              },
              {
                "type": "text",
                "text": "!"
              }
            ]
          }
        ]
      }
    },
    {
      "label": "can add a mark in a nested node",
      "type": "addMark",
      "input": {
        "type": "doc",
        "content": [
          {
            "type": "blockquote",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "the variable is called i"
                  }
                ]
              }
            ]
          }
        ]
      },
      "from": 25,
      "to": 26,
      "mark": "code",
      "expected": {
        "type": "doc",
        "content": [
          {
            "type": "blockquote",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "the variable is called "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "i"
                  }
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "label": "can cut a gap",
      "type": "removeMark",
      "input": {
        "type": "doc",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "marks": [
                  {
                    "type": "em"
                  }
                ],
                "text": "hello world!"
              }
            ]
          }
        ]
      },
      "from": 7,
      "to": 12,
      "mark": "em",
      "expected": {
        "type": "doc",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "marks": [
                  {
                    "type": "em"
                  }
                ],
                "text": "hello "
              },
              {
                "type": "text",
                "text": "world"
              },
              {
                "type": "text",
                "marks": [
                  {
                    "type": "em"
                  }
                ],
                "text": "!"
              }
            ]
          }
        ]
      }
    }
  ]
}