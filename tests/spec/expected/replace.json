{
  "cases": [
    {
      "label": "can delete text",
      "type": "replace",
      "input": {
        "type": "doc",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "hello you"
              }
            ]
          }
        ]
      },
      "from": 5,
      "to": 7,
      "slice": null,
      "expected": {
        "type": "doc",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "hellyou"
              }
            ]
          }
        ]
      }
    },
    {
      "label": "can join blocks",
      "type": "replace",
      "input": {
        "type": "doc",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "hello"
              }
            ]
          },
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "you"
              }
            ]
          }
        ]
      },
      "from": 5,
      "to": 8,
      "slice": null,
      "expected": {
        "type": "doc",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "hellyou"
              }
            ]
          }
        ]
      }
    },
    {
      "label": "can overwrite text",
      "type": "replace",
      "input": {
        "type": "doc",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "hello you"
              }
            ]
          }
        ]
      },
      "from": 5,
      "to": 7,
      "slice": {
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "i k"
              }
            ]
          }
        ]
      },
      "expected": {
        "type": "doc",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "hell"
              }
            ]
          },
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "i k"
              }
            ]
          },
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "you"
              }
            ]
          }
        ]
      }
    },
    {
      "label": "can add a textblock",
      "type": "replace",
      "input": {
        "type": "doc",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "helloyou"
              }
            ]
          }
        ]
      },
      "from": 6,
      "to": 6,
      "slice": {
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "there"
              }
            ]
          }
        ]
      },
      "expected": {
        "type": "doc",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "hello"
              }
            ]
          },
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "there"
              }
            ]
          },
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "you"
              }
            ]
          }
        ]
      }
    },
    {
      "label": "merges blocks across deleted content",
      "type": "replace",
      "input": {
        "type": "doc",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "a"
              }
            ]
          },
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "b"
              }
            ]
          },
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "c"
              }
            ]
          }
        ]
      },
      "from": 3,
      "to": 6,
      "slice": null,
      "expected": {
        "type": "doc",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "a"
              }
            ]
          },
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "c"
              }
            ]
          }
        ]
      }
    },
    {
      "label": "can delete the whole document",
      "type": "replace",
      "input": {
        "type": "doc",
        "content": [
          {
            "type": "heading",
            "attrs": {
              "level": 1
            },
            "content": [
              {
                "type": "text",
                "text": "hi"
              }
            ]
          },
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "you"
              }
            ]
          }
        ]
      },
      "from": 0,
      "to": 7,
      "slice": null,
      "expected": {
        "type": "doc",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "u"
              }
            ]
          }
        ]
      }
    }
  ]
}