{
  "cases": [
    {
      "label": "can insert a break",
      "type": "insert",
      "input": {
        "type": "doc",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "hellothere"
              }
            ]
          }
        ]
      },
      "pos": 6,
      "content": [
        {
          "type": "hard_break"
        }
      ],
      "expected": {
        "type": "doc",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "hello"
              },
              {
                "type": "hard_break"
              },
              {
                "type": "text",
                "text": "there"
              }
            ]
          }
        ]
      }
    },
    {
